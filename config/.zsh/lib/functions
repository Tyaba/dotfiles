function clean_downloads() {
	# :param duration: Filter downloads based on the file modification time in fd command such as "7 days".
	duration=$1
	fd -0 --changed-before "${duration}" --hidden . ~/Downloads | xargs -0 -I {} mv {} ~/.Trash
}

function gcloud() {
	command gcloud "$@"
	local ret=$?
	if [[ $ret -eq 0 && "$1" == "auth" && ("$2" == "login" || "$2" == "revoke") ]]; then
		local plist="$HOME/Library/LaunchAgents/com.tepein.yui-proxy.plist"
		if [[ "$2" == "revoke" ]]; then
			echo "[yui-proxy] stopping proxy (auth revoked)"
			launchctl unload "$plist" 2>/dev/null
		else
			echo "[yui-proxy] restarting proxy with new credentials..."
			launchctl unload "$plist" 2>/dev/null
			launchctl load "$plist"
		fi
	fi
	return $ret
}
