# Font (JetBrains Mono is Ghostty's default; Nerd Font variant for icon support)
font-family = JetBrainsMono Nerd Font
font-size = 14

# Theme
theme = Gruvbox Dark Hard

# Window
window-padding-x = 8
window-padding-y = 4
window-save-state = always

# Appearance
background-opacity = 0.96
background-blur = 20

# Scrollback (512MB; default 320MB is tight for long AI agent sessions)
scrollback-limit = 536870912

# Input
mouse-hide-while-typing = true

# Shell integration (auto-detect zsh/bash/fish)
shell-integration = detect

# Clipboard
clipboard-paste-protection = false
copy-on-select = clipboard

# Keybinds — tmux-friendly split/navigation
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom
