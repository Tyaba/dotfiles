{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "BASH_MAX_TIMEOUT_MS": "120000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "BASH_ENV": "",
    "ENV": "",
    "SHELL": "/bin/bash",
    "TERM": "dumb"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "List(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__yui__*",
      "mcp__playwright__*",
      "mcp__todoist__*",
      "mcp__codex__*",
      "mcp__claude_ai__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Cloud_BigQuery__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Notion__*",
      "mcp__claude_ai_SlackDB__*"
    ],
    "deny": [
      "Read(*credentials.json)",
      "Read(./secrets/**)",
      "Read(*/.env)",
      "Read(*/.env.*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Write(*/.env)",
      "Write(*/.env.*)",
      "Write(*/.ssh/*)",
      "Write(**/id_rsa*)",
      "Write(**/id_ed25519*)",
      "Bash(git :* push :* --force :*)",
      "Bash(git :* push :* -f :*)",
      "Bash(bq :* rm :*)",
      "Bash(bq :* delete :*)",
      "Bash(gcloud :* delete :*)",
      "Bash(gsutil :* rm :*)",
      "Bash(kubectl :* delete :*)",
      "Bash(gh :* repo :* delete :*)",
      "Bash(npm :* publish :*)",
      "Bash(twine :* upload :*)",
      "Bash(cargo :* publish :*)",
      "Bash(gem :* push :*)",
      "Bash(curl :* | bash :*)",
      "Bash(curl :* | sh :*)",
      "Bash(wget :* | bash :*)",
      "Bash(wget :* | sh :*)"
    ],
    "defaultMode": <%= ENV['DOTFILES_ROLE'] == 'devcontainer' ? '"bypassPermissions"' : '"auto"' %>
  },
  "model": "opus",
  "enabledMcpjsonServers": [],
<%
  # Match deny rules by serverUrl (with wildcards) instead of serverName.
  # Claude Code's settings schema constrains serverName to [A-Za-z0-9_-]+,
  # so labels that contain spaces or dots (e.g. "claude.ai Slack") fail
  # validation. URLs cover the same connectors without that restriction.
  # Entries whose host itself reveals internal product names are kept in
  # config/coding_agents/private/denied_mcp_servers.json.
  public_denied_mcp_servers = [
    { "serverUrl" => "https://mcp.slack.com/*" },
    { "serverUrl" => "https://mcp.canva.com/*" },
    { "serverUrl" => "https://mcp.heygen.com/*" },
    { "serverUrl" => "https://mcp.asana.com/*" },
    { "serverUrl" => "https://mcp.clickup.com/*" },
    { "serverUrl" => "https://mcp.monday.com/*" },
    { "serverUrl" => "https://mcp.atlassian.com/*" },
    { "serverUrl" => "https://microsoft365.mcp.claude.com/*" },
    { "serverUrl" => "https://mcp.box.com/*" },
    { "serverUrl" => "https://mcp.hubspot.com/*" },
    { "serverUrl" => "https://mcp.app.wiz.io/*" },
    { "serverUrl" => "https://mcp.zapier.com/*" },
    { "serverUrl" => "https://api.salesforce.com/platform/mcp/v1/analytics/tableau-next*" },
    { "serverUrl" => "https://listeningmind-service-mcp.ascentlab.io/*" },
  ]
  private_denied_mcp_path = ENV['DOTFILES_PRIVATE_DENIED_MCP_PATH'].to_s
  private_denied_mcp_servers =
    if !private_denied_mcp_path.empty? && File.exist?(private_denied_mcp_path)
      JSON.parse(File.read(private_denied_mcp_path))
    else
      []
    end
  denied_mcp_servers = public_denied_mcp_servers + private_denied_mcp_servers
  denied_mcp_lines = denied_mcp_servers.map { |e| "    #{JSON.generate(e)}" }.join(",\n")
-%>
  "deniedMcpServers": [
<%= denied_mcp_lines %>
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then afplay /System/Library/Sounds/Submarine.aiff; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"⏳ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux rename-window \"⏳ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/terraform-apply-guard.sh",
            "timeout": 120,
            "statusMessage": "terraform 操作の安全性を検証中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/render-diagram.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT=$(basename \"$PWD\"); if [ \"$(uname)\" = \"Darwin\" ]; then osascript -e \"display notification \\\"$PROJECT: タスク完了\\\" with title \\\"Claude Code\\\" sound name \\\"Submarine\\\"\"; else paplay /usr/share/sounds/freedesktop/stereo/message.oga; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"✅ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT=$(basename \"$PWD\"); if [ \"$(uname)\" = \"Darwin\" ]; then osascript -e \"display notification \\\"$PROJECT: 入力待ち\\\" with title \\\"Claude Code\\\" sound name \\\"Submarine\\\"\"; else paplay /usr/share/sounds/freedesktop/stereo/message.oga; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"❓ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "outputStyle": "Structured",
  "language": "日本語",
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "theme": "dark-daltonized"
}
