{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "BASH_MAX_TIMEOUT_MS": "120000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus",
    "BASH_ENV": "",
    "ENV": "",
    "SHELL": "/bin/bash",
    "TERM": "dumb"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "List(*)",
      "Fetch(https://*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Bash(uv :* sync :*)",
      "Bash(mise :* run :*)",
      "Bash(git :*)",
      "Bash(mkdir :*)",
      "Bash(*/ls :*)",
      "Bash(bq :* tail :*)",
      "Bash(bq :* show :*)",
      "Bash(mv :*)",
      "Bash(*/cat :*)",
      "Bash(cp :*)",
      "Bash(wc :*)",
      "Bash(*/grep :*)",
      "Bash(*/find :*)",
      "Bash(head :*)",
      "Bash(tree :*)",
      "Bash(gcloud :* describe :*)",
      "Bash(gcloud :* list :*)",
      "Bash(gcloud :* get-iam-policy :*)",
      "Bash(gcloud :* versions :* add :*)",
      "Bash(gcloud :* create :*)",
      "Bash(gcloud :* add-iam-policy-binding :*)",
      "Bash(gcloud :* config :*)",
      "mcp__yui__*"
    ],
    "deny": [
      "Read(*/.env)",
      "Read(*credentials.json)",
      "Read(./secrets/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Write(*/.ssh/*)",
      "Bash(bq :* rm :*)",
      "Bash(bq :* delete :*)",
      "Bash(gcloud :* delete :*)",
      "Bash(gsutil :* rm :*)",
      "Bash(terraform :* destroy :*)",
      "Bash(kubectl :* delete :*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "enabledMcpjsonServers": [
    "terraform",
    "svelte5"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then afplay /System/Library/Sounds/Submarine.aiff; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"⏳ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux rename-window \"⏳ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(terraform :* apply :*)",
            "command": "~/.claude/hooks/terraform-apply-guard.sh",
            "timeout": 120,
            "statusMessage": "terraform plan で安全性を検証中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/render-diagram.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT=$(basename \"$PWD\"); if [ \"$(uname)\" = \"Darwin\" ]; then osascript -e \"display notification \\\"$PROJECT: タスク完了\\\" with title \\\"Claude Code\\\" sound name \\\"Submarine\\\"\"; else paplay /usr/share/sounds/freedesktop/stereo/message.oga; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"✅ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT=$(basename \"$PWD\"); if [ \"$(uname)\" = \"Darwin\" ]; then osascript -e \"display notification \\\"$PROJECT: 入力待ち\\\" with title \\\"Claude Code\\\" sound name \\\"Submarine\\\"\"; else paplay /usr/share/sounds/freedesktop/stereo/message.oga; fi"
          },
          {
            "type": "command",
            "command": "tmux rename-window \"❓ $(basename \"$PWD\")\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "outputStyle": "Structured",
  "language": "日本語",
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipAutoPermissionPrompt": true
}
